<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#111111">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="pwebcam"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Low-latency USB webcam"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_stopped"
        android:textSize="16sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_toggle"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="@string/start_streaming"
        android:textSize="16sp" />

    <!-- Camera controls, visible only while streaming -->
    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone">

        <!-- EV row -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exposure"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_ev_down"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:text="−"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/tv_ev"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_ev_up"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:text="+"
                android:textSize="24sp" />

        </LinearLayout>

        <!-- Focus row — match_parent + weight so buttons always fit the screen -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_focus_picture"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Auto"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_focus_video"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Video"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_focus_fixed"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Fixed"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_focus_infinity"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="∞"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- Flash toggle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flash while streaming"
                android:textSize="12sp"
                android:textColor="#888888" />

            <Switch
                android:id="@+id/sw_flash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Camera2 hardware JPEG toggle — only shown when Camera2 is active -->
        <LinearLayout
            android:id="@+id/layout_cam2_jpeg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hardware JPEG (Camera2)"
                android:textSize="12sp"
                android:textColor="#888888" />

            <Switch
                android:id="@+id/sw_cam2_hw_jpeg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Flash brightness slider — only shown on devices that support torch strength (API 33+) -->
        <SeekBar
            android:id="@+id/seek_flash_brightness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connect USB → run receiver.py on Mac"
        android:textSize="12sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginTop="48dp" />

</LinearLayout>
